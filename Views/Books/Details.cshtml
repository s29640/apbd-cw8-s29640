@model APBD_cw8_s29640.Models.Book

@{
    ViewData["Title"] = "Book details";
}

<h1>Book details</h1>

<dl class="row">
    <dt class="col-sm-2">Title</dt>
    <dd class="col-sm-10">@Model.Title</dd>

    <dt class="col-sm-2">ISBN</dt>
    <dd class="col-sm-10">@Model.Isbn</dd>

    <dt class="col-sm-2">Published year</dt>
    <dd class="col-sm-10">@Model.PublishedYear</dd>

    <dt class="col-sm-2">Author</dt>
    <dd class="col-sm-10">@Model.Author.FirstName @Model.Author.LastName</dd>
</dl>

<p>
    <a asp-controller="Borrowings"
           asp-action="Create"
           asp-route-bookId="@Model.Id"
           class="btn btn-primary">
        Add borrowing
    </a>
</p>

<h2>Borrowing history</h2>

@if (!Model.Borrowings.Any())
{
    <p>No borrowings yet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Borrower</th>
                <th>Borrowed at</th>
                <th>Returned at</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var borrowing in Model.Borrowings.OrderByDescending(b => b.BorrowedAt))
            {
                <tr>
                    <td>@borrowing.BorrowerName</td>
                    <td>@borrowing.BorrowedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        @(borrowing.ReturnedAt.HasValue
                            ? borrowing.ReturnedAt.Value.ToString("yyyy-MM-dd HH:mm")
                            : "-")
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<a asp-action="Index" class="btn btn-secondary">Back</a>